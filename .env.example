# ===========================================
# SMB + Caddy File Server Configuration
# ===========================================
# Copy this file to .env and customize values
# cp .env.example .env

# -------------------------------------------
# Shared Directory
# -------------------------------------------
# Host directory to share via SMB and Web
# Examples:
#   ./shared          (relative path)
#   /data/home/files  (absolute path)
SHARED_DIR=./shared

# -------------------------------------------
# Samba Configuration
# -------------------------------------------
# Username for SMB authentication
SMB_USER=samba

# Password for SMB authentication
# WARNING: Change this to a strong password!
SMB_PASS=secret

# Bcrypt hash of SMB_PASS for Caddy Basic Auth
# Generate with: docker run --rm caddy:latest caddy hash-password --plaintext 'YOUR_PASSWORD'
# Or: caddy hash-password --plaintext 'YOUR_PASSWORD'
SMB_PASS_HASH=the_hased_value_example

# User ID and Group ID for file permissions
# Use `id -u` and `id -g` to find your current UID/GID
# This ensures proper file ownership in the shared directory
# Both Samba and Caddy use the same UID/GID since they share the same directory
PUID=1000
PGID=1000

# SMB port on host (avoid conflicts with host's SMB)
SMB_PORT=2445

# -------------------------------------------
# Caddy Web Server Configuration
# -------------------------------------------
# Web server port on host
WEB_PORT=18808
